# ─── Contracts directory ─────────────────────────────────────────────────────
# Absolute path to a directory containing markdown contract files.
# Works with any folder structure — Obsidian vaults, plain directories, etc.
CONTRACT_PDF_CONTRACTS_DIR=

# ─── Branding ────────────────────────────────────────────────────────────────
# Your company/brand name shown on the contract cover page.
CONTRACT_PDF_BRAND_NAME=My Company
# Absolute path to your logo image (webp, png, jpg, or svg).
CONTRACT_PDF_LOGO_PATH=

# ─── Output directory ────────────────────────────────────────────────────────
# Where rendered HTML/PDF contracts are saved. Defaults to ~/.local/share/contract-pdf-mcp/generated
CONTRACT_PDF_GENERATED_DIR=

# ─── Template directory ──────────────────────────────────────────────────────
# Strongly recommended for shared or branded deployments.
# Absolute path to the directory containing your contract style templates.
# Must contain at least default.html and default.css.
# If unset, the server uses the bundled templates shipped with this package/repo.
CONTRACT_PDF_TEMPLATE_DIR=

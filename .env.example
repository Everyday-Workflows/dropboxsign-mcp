# ─── Required ────────────────────────────────────────────────────────────────
# Your Dropbox Sign API key from https://app.hellosign.com/home/myAccount#api
DROPBOXSIGN_API_KEY=

# ─── Recommended ─────────────────────────────────────────────────────────────
# Set to true while testing. Requests will not consume quota or send real emails.
DROPBOXSIGN_TEST_MODE=true

# Your Dropbox Sign API app client_id. Used for branding on signature/template requests.
DROPBOXSIGN_CLIENT_ID=

# ─── Signer preset ("me") ────────────────────────────────────────────────────
# Pre-fill your own signer info so you don't have to type it on every send.
DROPBOXSIGN_SIGNER_NAME=
DROPBOXSIGN_SIGNER_EMAIL=
# The role label that represents you in templates (default: Service Provider)
DROPBOXSIGN_SIGNER_ROLE=Service Provider

# ─── Vault ───────────────────────────────────────────────────────────────────
# Absolute path to your Obsidian vault root. Used by vault_list_contracts.
DROPBOXSIGN_VAULT_PATH=

# ─── Branding ────────────────────────────────────────────────────────────────
# Your company/brand name shown on the contract cover page.
DROPBOXSIGN_BRAND_NAME=My Company
# Absolute path to your logo image (webp, png, jpg, or svg).
DROPBOXSIGN_LOGO_PATH=

# ─── Output directories ──────────────────────────────────────────────────────
# Where rendered HTML/PDF contracts are saved. Defaults to ~/.local/share/dropboxsign-mcp/generated
DROPBOXSIGN_GENERATED_DIR=
# Where downloaded signed documents are saved. Defaults to ~/.local/share/dropboxsign-mcp/downloads
DROPBOXSIGN_DOWNLOAD_DIR=
# Where HTML/CSS brand templates live. Defaults to ./templates in the repo root.
DROPBOXSIGN_TEMPLATE_DIR=

{
  "name": "@alexautomates/dropboxsign-mcp",
  "version": "0.1.9",
  "type": "module",
  "description": "Local-first MCP server for Dropbox Sign: render branded contract PDFs, create template drafts, and send/manage signature requests.",
  "license": "MIT",
  "homepage": "https://github.com/Everyday-Workflows/dropboxsign-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Everyday-Workflows/dropboxsign-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Everyday-Workflows/dropboxsign-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dropbox-sign",
    "hellosign",
    "esignature",
    "contracts",
    "document-automation",
    "typescript"
  ],
  "bin": {
    "dropboxsign-mcp": "bin/dropboxsign-mcp.js"
  },
  "files": [
    "bin",
    "dist/src",
    "templates",
    ".env.example"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prepack": "npm run build",
    "start": "node dist/src/index.js",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@dropbox/sign": "^1.10.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "playwright": "^1.58.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}

{
  "name": "@alexautomates/contract-pdf-mcp",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "description": "Local-first MCP server for rendering branded contract PDFs from markdown and reusable HTML/CSS templates.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Everyday-Workflows/dropboxsign-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "contracts",
    "pdf",
    "templates",
    "document-automation",
    "typescript"
  ],
  "bin": {
    "contract-pdf-mcp": "bin/contract-pdf-mcp.js"
  },
  "files": [
    "bin",
    "dist/src",
    "templates",
    ".env.example"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prepack": "npm run build",
    "start": "node dist/src/index.js",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "playwright": "^1.58.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
